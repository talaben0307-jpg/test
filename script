-- ==========================================
-- HÀM TẢI SCRIPT AN TOÀN (SAFE LOAD)
-- ==========================================
local function SafeLoad(url, name)
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if success then
        Fluent:Notify({Title = "THÀNH CÔNG", Content = "Đã chạy script: " .. name, Duration = 3})
    else
        Fluent:Notify({Title = "THẤT BẠI", Content = "Lỗi khi tải " .. name .. "! Vui lòng thử lại sau.", Duration = 5})
        warn("Lỗi Script [" .. name .. "]: " .. tostring(err))
    end
end

-- ==========================================
-- HÀM TẢI ẢNH TỪ GOOGLE DRIVE HOẶC URL LỚN
-- ==========================================
local function GetOnlineImage(url, fileName)
    local success, result = pcall(function()
        if not isfile(fileName) then
            writefile(fileName, game:HttpGet(url))
        end
        return getcustomasset(fileName)
    end)
    if success then
        return result
    else
        warn("Lỗi nạp ảnh từ URL: " .. tostring(result))
        return ""
    end
end

